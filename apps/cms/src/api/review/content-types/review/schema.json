{
  "kind": "collectionType",
  "collectionName": "reviews",
  "info": { "singularName": "review", "pluralName": "reviews", "displayName": "Review" },
  "options": { "draftAndPublish": false },
  "attributes": {
    "name": { "type": "string", "required": true },
    "slug": { "type": "uid", "required": true },
    "emailHash": { "type": "string" },
    "rating": { "type": "integer", "min": 1, "max": 5, "required": true },
    "comment": { "type": "text", "required": true },
    "moderationStatus": { "type": "enumeration", "enum": ["pending", "approved", "rejected"], "default": "pending", "required": true },
    "product": { "type": "relation", "relation": "manyToOne", "target": "api::product.product", "inversedBy": "reviews" }
  }
}
